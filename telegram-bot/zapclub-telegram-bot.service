[Unit]
Description=zapclub Telegram Bridge Bot
After=network.target zapclub-relay.service
Wants=zapclub-relay.service

[Service]
Type=simple
User=webmaster
WorkingDirectory=/home/webmaster/telegram-bot
EnvironmentFile=/home/webmaster/telegram-bot/.env
ExecStart=/home/webmaster/telegram-bot/zapclub-telegram-bot
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
