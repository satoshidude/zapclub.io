# Copy to relay.env (chmod 600) and fill in. NEVER commit relay.env.
# Generate a fresh key: openssl rand -hex 32
RELAY_SECRET_KEY=
RELAY_NAME=zapclub.io
RELAY_DESCRIPTION=NIP-29 relay for zapclub.io
RELAY_DOMAIN=relay.zapclub.io
# Bind address (Caddy proxies to this; never expose externally)
RELAY_BIND=127.0.0.1:3334
RELAY_DB_PATH=./db
