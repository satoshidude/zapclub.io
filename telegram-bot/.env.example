# ── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=

# Telegram group/channel chat ID (negative number for groups, e.g. -1001234567890)
# Run the bot once without this set, then add it to a group and send /start
# to find it; or use @userinfobot.
TELEGRAM_CHAT_ID=

# Nostr secret key for the bot identity (nsec1...)
# Generate a fresh one: go run main.go genkey
BOT_NSEC=

# NIP-29 group ID of the bot's zapclub club
# Create the club via zapclub.io while logged in with the bot's key,
# then paste the group ID here (short random string shown in the URL).
BOT_CLUB_ID=

# ── Optional ────────────────────────────────────────────────────────────────

# Relay WebSocket URL (default: wss://relay.zapclub.io)
# RELAY_URL=wss://relay.zapclub.io

# Relay HTTP API base URL for /yt-search (default: https://relay.zapclub.io)
# RELAY_API=https://relay.zapclub.io
