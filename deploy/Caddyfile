# zapclub.io — Caddy reverse proxy / static host
# www.zapclub.io currently points to a different IP, so it is intentionally
# NOT included here (ACME cert would fail). Add it once DNS points at this box.
#
# The NIP-29 relay (relay.zapclub.io) listens on 127.0.0.1:3334 and will be
# proxied here once it is deployed — block stubbed below, commented out.

{
	email admin@zapclub.io
}

zapclub.io {
	encode zstd gzip

	# YouTube search/playlist proxy → relay (yt-dlp). Same-origin so the frontend
	# avoids CORS; the relay rate-limits these per IP. `handle` blocks are mutually
	# exclusive and ordered, so these win over the SPA fallback (try_files would
	# otherwise rewrite /yt-search → /index.html before any reverse_proxy matcher).
	handle /yt-search* {
		reverse_proxy 127.0.0.1:3334
	}
	handle /yt-playlist* {
		reverse_proxy 127.0.0.1:3334
	}

	# Everything else: static SPA with history-router fallback.
	handle {
		root * /var/www/zapclub
		try_files {path} /index.html
		file_server
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		# CSP notes: script-src needs www.youtube.com (IFrame API + widget script);
		# frame-src both YT embed hosts; img-src https: because covers/avatars come from
		# arbitrary user-supplied hosts (kind-0 pictures, Blossom, robohash) and data: for
		# dicebear club avatars; connect-src https:/wss: because LNURL endpoints and
		# NIP-46 bunker relays are arbitrary; style-src 'unsafe-inline' for Svelte
		# style attributes (e.g. dancefloor --x/--y vars).
		Content-Security-Policy "default-src 'self'; script-src 'self' https://www.youtube.com https://s.ytimg.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com; img-src 'self' data: https:; connect-src 'self' https: wss:; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; manifest-src 'self'"
		-Server
	}
}

relay.zapclub.io {
	# Nostr relay — WebSocket upgrade is handled transparently by reverse_proxy.
	reverse_proxy 127.0.0.1:3334

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		# WS/JSON endpoint only — nothing here should ever render or be framed.
		Content-Security-Policy "default-src 'none'; frame-ancestors 'none'"
	}
}
